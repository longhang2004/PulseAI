# ==============================================================================
# PULSEAI GLOBAL ENVIRONMENT CONFIGURATION
# ==============================================================================

# --- DATABASE (TimescaleDB / PostgreSQL) ---
TIMESCALEDB_HOST=localhost
TIMESCALEDB_PORT=5432
TIMESCALEDB_USER=postgres
TIMESCALEDB_PASSWORD=pulseai_secure_pass_2026
TIMESCALEDB_DB=pulseai
SIGNAL_RETENTION_DAYS=7

# --- CACHE & COUNTERS (Redis) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- MESSAGE BROKER (Kafka) ---
KAFKA_BROKERS=localhost:9092

# --- AUTHENTICATION ---
JWT_SECRET=pulseai_super_secret_jwt_sign_key_change_me_in_prod

# --- AI & DIAGNOSIS SERVICE ---
# LLM_PROVIDER can be: 'anthropic' | 'openai' | 'ollama'
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
OLLAMA_ENDPOINT=http://localhost:11434

# --- ALERT NOTIFICATION CHANNELS ---
SENDGRID_API_KEY=your-sendgrid-api-key-here
SLACK_WEBHOOK_URL=your-slack-webhook-url-here

# ==============================================================================
# SERVICE SPECIFIC PORTS (Defined in CLAUDE.md)
# ==============================================================================
PORT_INGEST_GATEWAY=3000
PORT_STREAM_PROCESSOR=8080
PORT_DIAGNOSIS_SERVICE=3001
PORT_ALERT_SERVICE=3002
PORT_API_SERVICE=3003
PORT_FRONTEND=4000
